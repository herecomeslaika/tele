# A2A_min_v1 — Environment Configuration Template
# Copy this file to .env and fill in actual values.

# --- Provider ---
PROVIDER_ADAPTER=mock                          # mock | real
PROVIDER_ENDPOINT=https://api.deepseek.com/v1  # DeepSeek API base URL
PROVIDER_API_KEY=sk-4d34610d6deb40dbbe2edaa3eb2c72d7          # API key (replace with real key)
PROVIDER_MODEL=deepseek-chat                   # Model name

# --- Gateway ---
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# --- Timeouts (seconds) ---
REQUEST_TIMEOUT=30
STREAM_TIMEOUT=120
HEARTBEAT_INTERVAL=15

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json                                # json | text
