# A2A_min_v1 — Full Environment Configuration
# Copy this file to .env and fill in actual values.

# === Protocol ===
PROTOCOL_VERSION=v1
PROTOCOL_COMPATIBILITY=true                   # Support CSD_Stream_v0 legacy names

# === Provider Configuration ===
# Primary provider (OpenAI-compatible)
PROVIDER1_TYPE=openai_compatible
PROVIDER1_NAME=deepseek
PROVIDER1_ENDPOINT=https://api.deepseek.com/v1
PROVIDER1_API_KEY=sk-4d34610d6deb40dbbe2edaa3eb2c72d7
PROVIDER1_MODEL=deepseek-chat
PROVIDER1_TIMEOUT=60
PROVIDER1_MAX_TOKENS=2048
PROVIDER1_TEMPERATURE=0.7

# Secondary provider (Anthropic-compatible)
PROVIDER2_TYPE=anthropic_compatible
PROVIDER2_NAME=claude
PROVIDER2_ENDPOINT=https://api.anthropic.com
PROVIDER2_API_KEY=sk-ant-xxx
PROVIDER2_MODEL=claude-sonnet-4-6-20250514
PROVIDER2_TIMEOUT=60
PROVIDER2_MAX_TOKENS=2048
PROVIDER2_TEMPERATURE=0.7

# Local model (Ollama)
PROVIDER3_TYPE=ollama
PROVIDER3_NAME=qwen-local
PROVIDER3_ENDPOINT=http://localhost:11434/v1
PROVIDER3_API_KEY=unused
PROVIDER3_MODEL=qwen2.5:0.5b
PROVIDER3_TIMEOUT=120
PROVIDER3_MAX_TOKENS=2048

# === Gateway ===
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_STRATEGY=priority                     # priority | hash | round_robin | model_name | task_type | capability

# === Timeouts (seconds) ===
FIRST_TOKEN_TIMEOUT=30
TOKEN_INTERVAL_TIMEOUT=15
TOTAL_TASK_TIMEOUT=120
PROVIDER_RESPONSE_TIMEOUT=60

# === Heartbeat ===
HEARTBEAT_INTERVAL=15

# === Retry ===
MAX_RETRIES=3
RETRY_BASE_DELAY=1
RETRY_MAX_DELAY=30
RETRY_BACKOFF_FACTOR=2

# === Flow Control ===
MAX_QUEUE_LENGTH=1000
SEND_RATE_LIMIT=100

# === Security ===
SECURITY_ENABLED=true
REQUIRE_AGENT_ID=true
MAX_INPUT_LENGTH=10000
MAX_OUTPUT_LENGTH=50000

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json

# === Metrics ===
METRICS_ENABLED=true

# === Audit ===
AUDIT_ENABLED=true
AUDIT_LOG_DIR=evidence/audit